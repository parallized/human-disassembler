{
  "name": "human-disassembler",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n server,client -c auto \"bun run dev:server\" \"bun run dev:frontend\"",
    "dev:server": "bun --hot server/index.tsx",
    "dev:frontend": "vite",
    "build:frontend": "vite build",
    "build": "bun run build:frontend && bun build ./server/index.tsx --outdir dist --target bun",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun run build"
  },
  "dependencies": {
    "hono": "^4.9.9",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@unocss/preset-uno": "^66.5.1",
    "@unocss/vite": "^66.6.6",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.3",
    "unocss": "^66.5.1",
    "vite": "^7.3.1"
  }
}
